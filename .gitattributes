# Repo policy: LF in the repository AND in the working tree, on every
# platform. Emacs, Gradle, and Android Studio are all LF-safe on Windows,
# and the elisp test runners execute under WSL where CRLF breaks sh and
# poisons byte-for-byte artifact checks. Renormalized 2026-07-13.
* text=auto eol=lf

# Windows batch files are the one CRLF-native format.
*.bat text eol=crlf

# Binary formats git must never touch.
*.png binary
*.webp binary
*.jar binary

# Generated canonical artifact — pin to LF so byte-for-byte drift checks are
# stable across platforms (the working tree stays LF even with core.autocrlf).
docs/contract.json text eol=lf
