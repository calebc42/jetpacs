<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Loopback TCP still requires INTERNET; goes away with the UDS swap. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Runtime-requested on API 33+ (MainActivity drives the request). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Foreground service + the API 34 type-specific companion permission. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Eabp">
        <!-- ^ Match your existing theme name from themes.xml if it differs. -->

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          specialUse is the honest FGS type for a persistent local-IPC bridge:
          dataSync gets a ~6h timeout on Android 15, and nothing else fits.
          The PROPERTY explains the use to Play review (required for the type).
        -->
        <service
            android:name=".BridgeService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Hosts a local loopback socket bridge so GNU Emacs (a separate on-device app) can post notifications and render widgets through this app. The service must persist to accept connections and respond to notification actions." />
        </service>

        <!-- Internal only: notification action PendingIntents target it directly. -->
        <receiver
            android:name=".ActionReceiver"
            android:exported="false" />

        <receiver
            android:name=".EabpWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/eabp_widget_info" />
        </receiver>

    </application>

</manifest>