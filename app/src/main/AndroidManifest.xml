<?xml version="1.0" encoding="utf-8"?>
<!-- Glasspane shell manifest: app identity only. The Jetpacs components
     (bridge service, action plumbing, widgets, tiles, reminders) and their
     permissions merge in from the :jetpacs library manifest. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Onboarding writes glasspane.el into /sdcard/Documents. On API 29+
         that goes through MediaStore (no permission needed); this covers the
         legacy direct-file path on API 24-28 only. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_glasspane"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_glasspane"
        android:supportsRtl="true"
        android:theme="@style/Theme.Jetpacs">
        <!-- ^ Match your existing theme name from themes.xml if it differs. -->

        <!-- adjustResize: required for IME window insets to be reported on
             API < 30; the compose side (imePadding in SduiScaffold) does the
             actual lifting of keyboard-adjacent content. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Share sheet → org capture. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Quick Settings tile: one-tap org capture — a Glasspane opinion,
             so it lives in the shell, not the library. exported + the bind
             permission are both required for the system to host the tile. -->
        <service
            android:name=".CaptureTileService"
            android:exported="true"
            android:icon="@drawable/ic_widget_add"
            android:label="@string/tile_capture_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>

</manifest>
