<?xml version="1.0" encoding="utf-8"?>
<!-- Reference companion shell manifest: app identity only. The Jetpacs
     components (bridge service, action plumbing, widgets, tiles, reminders)
     and their permissions merge in from the :jetpacs library manifest. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Onboarding writes jetpacs-core.el into /sdcard/Documents. On API 29+
         that goes through MediaStore (no permission needed); this covers the
         legacy direct-file path on API 24-28 only. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_jetpacs"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_jetpacs"
        android:supportsRtl="true"
        android:theme="@style/Theme.Jetpacs">
        <!-- ^ Match your existing theme name from themes.xml if it differs. -->

        <!-- adjustResize: required for IME window insets to be reported on
             API < 30; the compose side (imePadding in SduiScaffold) does the
             actual lifting of keyboard-adjacent content. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Share sheet → the app-agnostic share.text action; whatever
                 Tier 1 is loaded decides what receiving text means. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- QS tiles are elisp-composed: the library's tile:customN slots
             (TileSlots.kt) render whatever the loaded app pushes, so this
             shell declares no tiles of its own. -->

    </application>

</manifest>
