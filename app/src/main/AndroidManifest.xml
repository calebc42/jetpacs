<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Loopback TCP still requires INTERNET; goes away with the UDS swap. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Runtime-requested on API 33+ (MainActivity drives the request). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Foreground service + the API 34 type-specific companion permission. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Exact-alarm reminders for timed org items (user-grantable on 12+;
         the handshake already reports canScheduleExactAlarms to Emacs). -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Eabp">
        <!-- ^ Match your existing theme name from themes.xml if it differs. -->

        <!-- adjustResize: required for IME window insets to be reported on
             API < 30; the compose side (imePadding in SduiScaffold) does the
             actual lifting of keyboard-adjacent content. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Share sheet → org capture. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!--
          specialUse is the honest FGS type for a persistent local-IPC bridge:
          dataSync gets a ~6h timeout on Android 15, and nothing else fits.
          The PROPERTY explains the use to Play review (required for the type).
        -->
        <service
            android:name=".BridgeService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Hosts a local loopback socket bridge so GNU Emacs (a separate on-device app) can post notifications and render widgets through this app. The service must persist to accept connections and respond to notification actions." />
        </service>

        <!-- Adapter behind the agenda widget's scrollable list; the system
             binds it with BIND_REMOTEVIEWS. -->
        <service
            android:name=".AgendaWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <!-- Invisible click router for agenda list rows (see the class doc).
             NoDisplay + finish-in-onCreate: never visible, never in recents.
             singleInstance + its own task affinity keep it OUT of the app's
             task — with the default affinity, launching it yanks the whole
             app task (MainActivity included) to the foreground. -->
        <activity
            android:name=".ActionTrampolineActivity"
            android:theme="@android:style/Theme.NoDisplay"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:launchMode="singleInstance"
            android:taskAffinity="com.calebc42.eabp.trampoline"
            android:exported="false" />

        <!-- Agenda-widget view selector: a floating chooser over the home
             screen. Its own task affinity for the same reason as the
             trampoline — the app task must not come forward. -->
        <activity
            android:name=".WidgetViewSelectionActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity="com.calebc42.eabp.widgetdialog"
            android:exported="false" />

        <!-- Quick Settings tile: one-tap org capture. exported + the bind
             permission are both required for the system to host the tile. -->
        <service
            android:name=".CaptureTileService"
            android:exported="true"
            android:icon="@drawable/ic_widget_add"
            android:label="@string/tile_capture_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Internal only: notification action PendingIntents target it directly. -->
        <receiver
            android:name=".ActionReceiver"
            android:exported="false" />

        <!-- Fires reminder alarms scheduled by ReminderScheduler. -->
        <receiver
            android:name=".ReminderReceiver"
            android:exported="false" />

        <receiver
            android:name=".EabpWidgetProvider"
            android:label="@string/widget_agenda_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/eabp_widget_info" />
        </receiver>

        <receiver
            android:name=".EabpClockWidgetProvider"
            android:label="@string/widget_clock_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/eabp_clock_widget_info" />
        </receiver>

    </application>

</manifest>