<?xml version="1.0" encoding="utf-8"?>
<!-- Jetpacs library manifest: the app-agnostic components (bridge service,
     action plumbing, widgets, tiles, reminders) merge into any host app.
     Class names are fully qualified because the library namespace
     (com.calebc42.jetpacs.core) differs from the Kotlin package the classes
     keep (com.calebc42.jetpacs). -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Loopback TCP still requires INTERNET; goes away with the UDS swap. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Runtime-requested on API 33+ (the host activity drives the request). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Foreground service + the API 34 type-specific companion permission. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Exact-alarm reminders for timed org items (user-grantable on 12+;
         the handshake already reports canScheduleExactAlarms to Emacs). -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- The `vibrate` effector (SPEC §10). Install-time, not runtime. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Reboot persistence (SPEC §11): rearm triggers, reschedule reminders. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- `network` triggers (SPEC §11): the default-network callback. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Special access the effectors gate on (SPEC §10). DECLARING these
         is what makes the app appear in the system grant screens at all —
         without the declaration the "Modify system settings" / "Do Not
         Disturb access" lists simply omit it. Nothing is granted by
         declaration alone; the user flips the toggle. -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!-- Runtime permissions the connectivity triggers use (wifi.ssid /
         bluetooth.device, SPEC §11). Declared so the rows exist under
         App info → Permissions; granted there (or via a future runtime
         prompt), never silently. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Android 11 package visibility: without these, `apps.list` returns
         nothing and TTS finds no engine. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <application>

        <!--
          specialUse is the honest FGS type for a persistent local-IPC bridge:
          dataSync gets a ~6h timeout on Android 15, and nothing else fits.
          The PROPERTY explains the use to Play review (required for the type).
        -->
        <service
            android:name="com.calebc42.jetpacs.BridgeService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Hosts a local loopback socket bridge so GNU Emacs (a separate on-device app) can post notifications and render widgets through this app. The service must persist to accept connections and respond to notification actions." />
        </service>

        <!-- Adapter behind every scrollable widget list (agenda + custom
             slots); the system binds it with BIND_REMOTEVIEWS. -->
        <service
            android:name="com.calebc42.jetpacs.JetpacsWidgetListService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <!-- Invisible click router for agenda list rows (see the class doc).
             NoDisplay + finish-in-onCreate: never visible, never in recents.
             singleInstance + its own task affinity keep it OUT of the app's
             task — with the default affinity, launching it yanks the whole
             app task (the host activity included) to the foreground. -->
        <activity
            android:name="com.calebc42.jetpacs.ActionTrampolineActivity"
            android:theme="@android:style/Theme.NoDisplay"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:launchMode="singleInstance"
            android:taskAffinity="com.calebc42.jetpacs.trampoline"
            android:exported="false" />

        <!-- Agenda-widget view selector: a floating chooser over the home
             screen. Its own task affinity for the same reason as the
             trampoline — the app task must not come forward. -->
        <activity
            android:name="com.calebc42.jetpacs.WidgetViewSelectionActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity="com.calebc42.jetpacs.widgetdialog"
            android:exported="false" />

        <!-- Blank Elisp-composed tile slots (tile:custom1..5). ACTIVE_TILE:
             the system refreshes them only on requestListeningState, which
             SurfaceManager fires on each tile surface push. -->
        <service
            android:name="com.calebc42.jetpacs.JetpacsTile1"
            android:exported="true"
            android:icon="@drawable/ic_widget_add"
            android:label="@string/widget_custom_label_1"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
        </service>
        <service
            android:name="com.calebc42.jetpacs.JetpacsTile2"
            android:exported="true"
            android:icon="@drawable/ic_widget_add"
            android:label="@string/widget_custom_label_2"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
        </service>
        <service
            android:name="com.calebc42.jetpacs.JetpacsTile3"
            android:exported="true"
            android:icon="@drawable/ic_widget_add"
            android:label="@string/widget_custom_label_3"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
        </service>
        <service
            android:name="com.calebc42.jetpacs.JetpacsTile4"
            android:exported="true"
            android:icon="@drawable/ic_widget_add"
            android:label="@string/widget_custom_label_4"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
        </service>
        <service
            android:name="com.calebc42.jetpacs.JetpacsTile5"
            android:exported="true"
            android:icon="@drawable/ic_widget_add"
            android:label="@string/widget_custom_label_5"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
        </service>

        <!-- Internal only: notification action PendingIntents target it directly. -->
        <receiver
            android:name="com.calebc42.jetpacs.ActionReceiver"
            android:exported="false" />

        <!-- Fires reminder alarms scheduled by ReminderScheduler. -->
        <receiver
            android:name="com.calebc42.jetpacs.ReminderReceiver"
            android:exported="false" />

        <!-- Fires `time` triggers (SPEC §11); alarm PendingIntents only. -->
        <receiver
            android:name="com.calebc42.jetpacs.TriggerAlarmReceiver"
            android:exported="false" />

        <!-- Reboot persistence: rearm triggers + reminders, restart the
             bridge (BOOT_COMPLETED is FGS-start exempt). Protected system
             broadcast, so exported=false still receives it. -->
        <receiver
            android:name="com.calebc42.jetpacs.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="com.calebc42.jetpacs.JetpacsWidgetProvider"
            android:label="@string/widget_agenda_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/jetpacs_widget_info" />
        </receiver>

        <!-- Blank Elisp-composed widget slots (Tasker-style): five identical
             receivers, each bound to its widget:customN surface. -->
        <receiver
            android:name="com.calebc42.jetpacs.JetpacsCustomWidget1"
            android:label="@string/widget_custom_label_1"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/jetpacs_custom_widget_info" />
        </receiver>
        <receiver
            android:name="com.calebc42.jetpacs.JetpacsCustomWidget2"
            android:label="@string/widget_custom_label_2"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/jetpacs_custom_widget_info" />
        </receiver>
        <receiver
            android:name="com.calebc42.jetpacs.JetpacsCustomWidget3"
            android:label="@string/widget_custom_label_3"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/jetpacs_custom_widget_info" />
        </receiver>
        <receiver
            android:name="com.calebc42.jetpacs.JetpacsCustomWidget4"
            android:label="@string/widget_custom_label_4"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/jetpacs_custom_widget_info" />
        </receiver>
        <receiver
            android:name="com.calebc42.jetpacs.JetpacsCustomWidget5"
            android:label="@string/widget_custom_label_5"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/jetpacs_custom_widget_info" />
        </receiver>

        <receiver
            android:name="com.calebc42.jetpacs.JetpacsClockWidgetProvider"
            android:label="@string/widget_clock_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/jetpacs_clock_widget_info" />
        </receiver>

    </application>

</manifest>
