<?xml version="1.0" encoding="utf-8"?>
<!-- Google-Calendar-style agenda list. The rows live in a scrollable
     ListView (AgendaWidgetService); row and toggle taps both flow through
     one activity PendingIntent template targeting ActionTrampolineActivity,
     which either rebroadcasts (todo-cycle, invisible) or opens the app
     (heading jump) — the Glance trampoline pattern, since a collection
     allows only one template. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:paddingHorizontal="14dp"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/widget_title_area"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/widget_title_default"
                android:textStyle="bold"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/widget_text_primary" />

            <ImageView
                android:id="@+id/widget_title_arrow"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_widget_arrow_drop_down"
                android:tint="@color/widget_text_primary"
                android:visibility="gone"
                android:importantForAccessibility="no" />

        </LinearLayout>

        <TextView
            android:id="@+id/widget_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="11sp"
            android:visibility="gone"
            android:textColor="@color/widget_text_secondary" />

        <ImageButton
            android:id="@+id/widget_refresh"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:padding="5dp"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_widget_refresh"
            android:tint="@color/widget_text_primary"
            android:contentDescription="@string/widget_refresh" />

        <ImageButton
            android:id="@+id/widget_capture"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="2dp"
            android:padding="4dp"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_widget_add"
            android:tint="@color/widget_text_primary"
            android:contentDescription="@string/widget_capture" />

    </LinearLayout>

    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/widget_empty"
        android:textSize="13sp"
        android:textColor="@color/widget_text_secondary" />

    <ListView
        android:id="@+id/widget_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:scrollbars="none" />

</LinearLayout>